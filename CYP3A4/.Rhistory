library(dplyr)
library(tidyr)
load("E:/MVG/TFG/archivos_varios/AI_FINAL.RData")
counts <- assays(AI_FINAL)$countsPlus
genotypes <- as.matrix(rowData(AI_FINAL)$genotype)
samples <- colnames(AI_FINAL)
groups <- colData(AI_FINAL)$Group
is_het <- function(gt) grepl("0[\\|/]1", gt)
# 3. Crear tabla con datos: snp, sample, group, ref_count, alt_count
snp_ids <- rownames(genotypes)
results <- list()
for (i in seq_len(nrow(genotypes))) {
for (j in seq_len(ncol(genotypes))) {
gt <- genotypes[i, j]
if (!is_het(gt)) next  # solo heterocigotos
alleles <- unlist(strsplit(gt, "/|\\|"))
if (length(alleles) != 2) next
idx_ref <- which.max(table(alleles))  # suposición simple: el más común es el ref
idx1 <- switch(alleles[1], A = 1, C = 2, G = 3, T = 4)
idx2 <- switch(alleles[2], A = 1, C = 2, G = 3, T = 4)
counts_ij <- counts[i, j, ]
ref_count <- counts_ij[idx1]
alt_count <- counts_ij[idx2]
results[[length(results) + 1]] <- data.frame(
snp = snp_ids[i],
sample = samples[j],
group = as.character(groups[j]),
ref_count = ref_count,
alt_count = alt_count
)
}
}
nt_to_index <- c(A = 1, C = 2, G = 3, T = 4)
for (i in seq_len(nrow(genotypes))) {
for (j in seq_len(ncol(genotypes))) {
gt <- genotypes[i, j]
if (!is_het(gt)) next  # solo heterocigotos
alleles <- unlist(strsplit(gt, "/|\\|"))
if (length(alleles) != 2) next
idx1 <- nt_to_index[alleles[1]]
idx2 <- nt_to_index[alleles[2]]
if (is.na(idx1) || is.na(idx2)) next  # Saltar alelos no válidos
counts_ij <- counts[i, j, ]
ref_count <- counts_ij[idx1]
alt_count <- counts_ij[idx2]
results[[length(results) + 1]] <- data.frame(
snp = snp_ids[i],
sample = samples[j],
group = as.character(groups[j]),
ref_count = ref_count,
alt_count = alt_count
)
}
}
# 4. Unir todos los datos en un dataframe
df <- do.call(rbind, results)
# 5. Filtrar entradas sin lecturas o cobertura baja (opcional)
df <- df %>%
mutate(total = ref_count + alt_count) %>%
filter(total >= 10)
df <- bind_rows(results)
# 5. Filtrar entradas sin lecturas o cobertura baja (opcional)
df <- df %>%
mutate(total = ref_count + alt_count) %>%
filter(total >= 10)
# 6. Agrupar por SNP y grupo para sumar lecturas
df_summary <- df %>%
group_by(snp, group) %>%
summarise(
total_ref = sum(ref_count),
total_reads = sum(ref_count + alt_count),
.groups = "drop"
) %>%
pivot_wider(names_from = group, values_from = c(total_ref, total_reads), names_sep = "_")
