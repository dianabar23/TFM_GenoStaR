df <- df %>%
mutate(total = ref_count + alt_count) %>%
filter(total >= 10)
# 6. Agrupar por SNP y grupo
df_summary <- df %>%
group_by(snp, group) %>%
summarise(
total_ref = sum(ref_count),
total_reads = sum(ref_count + alt_count),
.groups = "drop"
) %>%
pivot_wider(
names_from = group,
values_from = c(total_ref, total_reads),
names_sep = "_"
)
# 7. Test estadístico (prop.test o fisher.test)
results_test <- df_summary %>%
rowwise() %>%
mutate(
p_value = tryCatch({
if (anyNA(c(total_ref_PNT, total_ref_UAM, total_reads_PNT, total_reads_UAM))) {
NA
} else if (any(c(total_reads_PNT, total_reads_UAM) == 0)) {
NA
} else {
mat <- matrix(c(
total_ref_PNT,
total_reads_PNT - total_ref_PNT,
total_ref_UAM,
total_reads_UAM - total_ref_UAM
), nrow = 2, byrow = TRUE)
if (any(mat < 5)) {
fisher.test(mat)$p.value
} else {
prop.test(
x = c(total_ref_PNT, total_ref_UAM),
n = c(total_reads_PNT, total_reads_UAM)
)$p.value
}
}
}, error = function(e) NA)
) %>%
ungroup() %>%
mutate(p_adj = p.adjust(p_value, method = "fdr")) %>%
arrange(p_adj)
# 8. Guardar resultados
write.csv(results_test, "E:/MVG/TFG/archivos_varios/prop_test_results.csv", row.names = FALSE)
# 9. Mostrar los 10 SNPs más significativos
head(results_test, 10)
barplot(AI_FINAL["rs1051488"], xlab.text="", legend.interspace=2)
barplot(AI_FINAL["rs1058026"], xlab.text="", legend.interspace=2)
barplot(AI_FINAL["rs1131500"], xlab.text="", legend.interspace=2)
barplot(AI_FINAL["rs1042229"], xlab.text="", legend.interspace=2)
barplot(AI_FINAL["rs9827878"], xlab.text="", legend.interspace=2)
library(ggplot2)
# Asegurarte de que los valores estén completos
plot_data <- results_test %>%
filter(!is.na(p_adj), !is.na(total_ref_PNT), !is.na(total_ref_UAM)) %>%
mutate(
# Calculamos proporciones de REF en cada grupo
prop_PNT = total_ref_PNT / total_reads_PNT,
prop_UAM = total_ref_UAM / total_reads_UAM,
log2_fc = log2(prop_PNT / prop_UAM),
neg_log10_padj = -log10(p_adj)
)
# Dibujar el volcano plot
ggplot(plot_data, aes(x = log2_fc, y = neg_log10_padj)) +
geom_point(alpha = 0.7) +
geom_vline(xintercept = c(-1, 1), linetype = "dashed", color = "grey") +
geom_hline(yintercept = -log10(0.05), linetype = "dashed", color = "red") +
theme_minimal() +
labs(
title = "Volcano Plot de ASE (PNT vs UAM)",
x = "Log2 Fold Change (PNT / UAM)",
y = "-Log10(p-valor ajustado)"
)
