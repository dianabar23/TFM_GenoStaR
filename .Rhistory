library(dplyr)
library(ggplot2)
library(writexl)
# Lista de genes
cyp_genes <- c("CYP1A2","CYP3A4","CYP3A5","CYP2C19","CYP2C9","CYP2B6","CYP2D6")
for (gene in cyp_genes) {
# Nombre del objeto dinámico
obj_name <- paste0(gene, "_resultados_final_diplotipos")
# Comprobar si existe
if (!exists(obj_name)) {
message(paste("No existe:", obj_name, "-> salto"))
next
}
# Cargar el objeto
obj <- get(obj_name)
# Extraer tabla (primer elemento de la lista)
df <- obj[[1]] %>%
select(LabID.V2,
paste0(gene, "_diplotype"),
paste0(gene, "_alternate_diplotype"))
# Renombrar columnas (opcional pero limpio)
colnames(df) <- c("LabID.V2", "Diplotype", "Alternate_diplotype")
# Guardar Excel
write_xlsx(df, paste0(gene, "_diplotipos.xlsx"))
# Frecuencias
freq <- df %>%
count(Diplotype, sort = TRUE)
# Gráfico
p <- ggplot(freq, aes(x = reorder(Diplotype, n), y = n)) +
geom_bar(stat = "identity") +
coord_flip() +
theme_minimal() +
labs(
title = paste("Frecuencia de diplotipos", gene),
x = "Diplotipo",
y = "Frecuencia"
) +
theme(plot.title = element_text(hjust = 0.5))
# Guardar gráfico
ggsave(paste0(gene, "_frecuencias.png"), plot = p, width = 8, height = 6)
message(paste("Procesado:", gene))
}
View(CYP3A5_resultados_final_diplotipos)
