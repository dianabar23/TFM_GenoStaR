## Ambos dan No Missing Genotypes
find_missing_data_MODIFICADO <- function(df) {
# Buscamos las posiciones que contienen exactamente "--"
missing_positions <- which(df == "--", arr.ind = TRUE)
# Si no hay ninguna fila en missing_positions, el dataframe está limpio
if (nrow(missing_positions) == 0) {
return("No Missing Genotypes")
}
# Generamos los mensajes para cada posición encontrada
missing_messages <- apply(missing_positions, 1, function(pos) {
row <- pos[1]
col <- pos[2]
# Extraemos el índice del paciente y el nombre del SNP/columna
patient_index <- df$Patient_index[row]
col_name <- colnames(df)[col]
paste("Missing Data: patient index", patient_index, ",", col_name)
})
return(as.list(missing_messages))
}
