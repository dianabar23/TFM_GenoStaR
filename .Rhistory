procesar_gen_completo <- function(gen, df_diplotipos) {
cat("\nProcesando:", gen, "\n")
col_diplo <- paste0(gen, "_diplotype")
if (!(col_diplo %in% colnames(df_diplotipos))) {
cat("⏭️ No hay diplotipo para", gen, "\n")
return(NULL)
}
# DIPLOTIPO
