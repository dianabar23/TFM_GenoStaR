library(AllelicImbalance)
library(VariantAnnotation)
library(GenomicRanges)
library(SummarizedExperiment)
load("E:/MVG/TFG/archivos_varios/GATK_FINAL.RData")
genotypes <- as.matrix(rowData(GATK_FINAL)$genotype)
counts <- assays(GATK_FINAL)$countsPlus
is_hom <- function(gt) grepl("^0[\\|/]0$|^1[\\|/]1$", gt)
for (i in seq_len(nrow(genotypes))) {
for (j in seq_len(ncol(genotypes))) {
gt <- genotypes[i, j]
if (is_hom(gt)) {
allele_counts <- counts[i, j, ]
if (sum(allele_counts > 0) > 1) {
main_allele_index <- which.max(allele_counts)
# Zeros para los demás alelos
counts[i, j, -main_allele_index] <- 0
}
}
}
}
assays(GATK_FINAL)$countsPlus <- counts
