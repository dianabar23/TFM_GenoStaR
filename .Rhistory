.groups = "drop"
) %>%
pivot_wider(names_from = group, values_from = c(total_ref, total_reads), names_sep = "_")
results_test <- df_summary %>%
rowwise() %>%
mutate(
p_value = tryCatch(
prop.test(
x = c(total_ref_Caso, total_ref_Control),
n = c(total_reads_Caso, total_reads_Control)
)$p.value,
error = function(e) NA
)
) %>%
ungroup() %>%
mutate(p_adj = p.adjust(p_value, method = "fdr")) %>%
arrange(p_adj)
write.csv(results_test, "E:/MVG/TFG/archivos_varios/prop_test_results.csv", row.names = FALSE)
